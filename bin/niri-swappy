#!/usr/bin/env bash

# niri-swappy
# Wrapper to capture a Niri screenshot and open it in Swappy

set -uo pipefail

# Add script directory to PATH to ensure sibling scripts (like dep_check) are found
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export PATH="$SCRIPT_DIR:$PATH"

# --- Dependencies ---
if [[ -z "${BATS_TEST_DIRNAME:-}" ]]; then
    dep_check "niri-swappy" "niri" "swappy" "jq" || exit 1
fi

# --- Helpers ---

die() {
    printf "niri-swappy: %s\n" "$1" >&2
    exit 1
}

current_desktop() {
    printf "%s" "${XDG_CURRENT_DESKTOP,,}"
}

# --- Validation ---

if [[ "$(current_desktop)" != "niri" ]]; then
    die "This tool is exclusive to the Niri compositor."
fi

ACTION="${1:-screenshot}"
TMP_FILE=$(mktemp --suffix=.png)

# 1. Trigger the Niri screenshot action.
# Using a specific --path overrides the default directory, preventing unwanted
# persistent files from cluttering the user's pictures folder until explicitly saved via Swappy.
niri msg action "$ACTION" --path "$TMP_FILE"

# 2. Block until the capture is complete.
# Niri's interactive actions are asynchronous. We use the event-stream to wait
# for the precise moment the screenshot is taken, or timeout if cancelled.
if timeout 60s sh -c 'niri msg --json event-stream | grep -m 1 "ScreenshotCaptured"' > /dev/null; then
    if [[ -s "$TMP_FILE" ]]; then
        swappy -f "$TMP_FILE"
    else
        echo "Error: Screenshot event captured but file not found." >&2
        rm -f "$TMP_FILE"
        exit 1
    fi
else
    # Timeout usually means the user pressed Escape to cancel
    rm -f "$TMP_FILE"
    exit 0
fi

# Clean up
rm -f "$TMP_FILE"
