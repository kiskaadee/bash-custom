#!/usr/bin/env bash

TARGET="$HOME/.bashrc"
SKELETON="/etc/skel/.bashrc"

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

HOOK="[[ \$- != *i* ]] && return
[[ -f \"$SCRIPT_DIR/main.sh\" ]] && source \"$SCRIPT_DIR/main.sh\""

echo "Checking $TARGET..."

# Ensure file exists
touch "$TARGET"

NEEDS_BACKUP=false

if [[ -s "$TARGET" ]]; then
    if [[ -f "$SKELETON" ]] && cmp -s "$TARGET" "$SKELETON"; then
        echo ".bashrc matches Arch skeleton. No backup needed."
    else
        echo ".bashrc differs from skeleton."
        NEEDS_BACKUP=true
    fi
else
    echo ".bashrc is empty."
fi

if $NEEDS_BACKUP; then
    BACKUP="$HOME/.bashrc.bak.$(date +%F-%H%M%S)"
    cp "$TARGET" "$BACKUP"
    echo "Backup saved to $BACKUP"
fi

echo "Rewriting $TARGET..."

: > "$TARGET"
printf "%s\n" "$HOOK" >> "$TARGET"

echo ".bashrc updated."

read -rp "Reload shell now? [Y/N]: " answer
case "$answer" in
    [Yy])
        exec "$SHELL"
        ;;
    *)
        echo "Open a new shell or run: source ~/.bashrc"
        ;;
esac